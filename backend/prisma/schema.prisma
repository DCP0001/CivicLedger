datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String?   // Nullable for voters who log in using wallet only
  walletAddress       String    @unique
  role                String    // "admin" or "voter"
  verificationStatus  String    @default("pending") // "pending" | "verified" | "rejected"
  verificationNotes   String?   // Optional admin review notes
  verifiedAt          DateTime? // Timestamp when verified or rejected
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  auditLogs           AuditLog[]
}

model Election {
  id             Int       @id // Manually matched to the smart contract electionId
  title          String
  description    String
  startDate      DateTime
  endDate        DateTime
  status         String    // "draft", "active", "ended", "archived"
  totalVotes     Int       @default(0) // Added for custom blockchain tracking
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  candidates     Candidate[]
  votes          VoteReference[]
}

model Candidate {
  id          Int      // Manually matched to the smart contract candidateId
  electionId  Int
  name        String
  party       String
  imageUrl    String
  description String
  voteCount   Int      @default(0) // Added for custom blockchain vote tracking
  election    Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@id([electionId, id])
}

model VoteReference {
  id              String   @id @default(uuid())
  electionId      Int
  walletAddress   String
  transactionHash String   @unique
  timestamp       DateTime @default(now())
  election        Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@unique([electionId, walletAddress]) // Enforce off-chain registration check
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Block {
  index        Int           @id
  timestamp    DateTime      @default(now())
  prevHash     String
  hash         String        @unique
  nonce        Int
  signature    String        // Signed by authority node
  transactions Transaction[]
}

model Transaction {
  id         String   @id // Transaction hash (sha256 of sender + payload + type + timestamp)
  blockIndex Int?
  type       String   // "CREATE_ELECTION" | "ADD_CANDIDATE" | "START_ELECTION" | "END_ELECTION" | "REGISTER_VOTER" | "CAST_VOTE"
  sender     String
  payload    String   // JSON string of input parameters
  signature  String
  timestamp  DateTime @default(now())
  block      Block?   @relation(fields: [blockIndex], references: [index], onDelete: Cascade)
}

model WhitelistedVoter {
  electionId    Int
  walletAddress String
  createdAt     DateTime @default(now())

  @@id([electionId, walletAddress])
}
